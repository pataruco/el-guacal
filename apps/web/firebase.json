[
  {
    "target": "web",
    "public": "build/client",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/__spa-fallback.html"
      }
    ]
  },
  {
    "target": "api",
    "public": "public_api_empty",
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "el-guacal-api",
          "region": "europe-west2"
        }
      }
    ]
  }
]
